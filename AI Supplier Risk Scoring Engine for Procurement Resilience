    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "from sklearn.model_selection import train_test_split\n",
    "from sklearn.ensemble import RandomForestClassifier\n",
    "from sklearn.metrics import classification_report, confusion_matrix, accuracy_score\n",
    "\n",
    "\n",
    "# --------------------------------------------------\n",
    "# 1. Synthetic supplier dataset generator\n",
    "# --------------------------------------------------\n",
    "\n",
    "def make_synthetic_supplier_data(n_suppliers=300, seed=42):\n",
    "    rng = np.random.default_rng(seed)\n",
    "\n",
    "    supplier_id = [f\"SUPP_{i+1:03d}\" for i in range(n_suppliers)]\n",
    "\n",
    "    df = pd.DataFrame({\n",
    "        \"supplier_id\": supplier_id,\n",
    "        \"otd_pct\": rng.uniform(70, 99.5, n_suppliers),\n",
    "        \"quality_ppm\": rng.uniform(50, 5000, n_suppliers),\n",
    "        \"lead_time_days\": rng.integers(7, 90, n_suppliers),\n",
    "        \"lead_time_std\": rng.uniform(1, 20, n_suppliers),\n",
    "        \"cost_index\": rng.uniform(0.85, 1.25, n_suppliers),\n",
    "        \"financial_score\": rng.uniform(30, 95, n_suppliers),\n",
    "        \"capacity_utilization_pct\": rng.uniform(55, 98, n_suppliers),\n",
    "        \"single_source_flag\": rng.integers(0, 2, n_suppliers),\n",
    "        \"geo_risk_score\": rng.uniform(10, 90, n_suppliers),\n",
    "        \"esg_score\": rng.uniform(40, 95, n_suppliers),\n",
    "    })\n",
    "\n",
    "    risk_score = (\n",
    "        (100 - df[\"otd_pct\"]) * 0.9 +\n",
    "        (df[\"quality_ppm\"] / 1000) * 1.6 +\n",
    "        df[\"lead_time_std\"] * 1.1 +\n",
    "        (df[\"lead_time_days\"] / 30) * 1.0 +\n",
    "        (df[\"cost_index\"] - 1.0) * 18 +\n",
    "        (100 - df[\"financial_score\"]) * 0.45 +\n",
    "        np.maximum(df[\"capacity_utilization_pct\"] - 85, 0) * 0.7 +\n",
    "        df[\"single_source_flag\"] * 10 +\n",
    "        df[\"geo_risk_score\"] * 0.22 +\n",
    "        (100 - df[\"esg_score\"]) * 0.12\n",
    "    )\n",
    "\n",
    "    risk_score += rng.normal(0, 2.5, n_suppliers)\n",
    "\n",
    "    # 這行不要寫成 df = df[\"risk_score_raw\"] = risk_score\n",
    "    df[\"risk_score_raw\"] = risk_score\n",
    "\n",
    "    # Quantile-based labels\n",
    "    q1 = df[\"risk_score_raw\"].quantile(0.33)\n",
    "    q2 = df[\"risk_score_raw\"].quantile(0.66)\n",
    "\n",
    "    conditions = [\n",
    "        df[\"risk_score_raw\"] < q1,\n",
    "        (df[\"risk_score_raw\"] >= q1) & (df[\"risk_score_raw\"] < q2),\n",
    "        df[\"risk_score_raw\"] >= q2\n",
    "    ]\n",
    "    labels = [0, 1, 2]\n",
    "\n",
    "    df[\"risk_label\"] = np.select(conditions, labels)\n",
    "\n",
    "    risk_map = {0: \"Low Risk\", 1: \"Medium Risk\", 2: \"High Risk\"}\n",
    "    df[\"risk_category\"] = df[\"risk_label\"].map(risk_map)\n",
    "\n",
    "    print(\"\\nRisk label distribution:\")\n",
    "    print(df[\"risk_label\"].value_counts().sort_index())\n",
    "    print(df[\"risk_category\"].value_counts())\n",
    "\n",
    "    return df\n",
    "\n",
    "# --------------------------------------------------\n",
    "# 4. Train classification model\n",
    "# --------------------------------------------------\n",
    "def train_supplier_risk_model(df: pd.DataFrame):\n",
    "    feature_cols = [\n",
    "        \"otd_pct\",\n",
    "        \"quality_ppm\",\n",
    "        \"lead_time_days\",\n",
    "        \"lead_time_std\",\n",
    "        \"cost_index\",\n",
    "        \"financial_score\",\n",
    "        \"capacity_utilization_pct\",\n",
    "        \"single_source_flag\",\n",
    "        \"geo_risk_score\",\n",
    "        \"esg_score\"\n",
    "    ]\n",
    "\n",
    "    X = df[feature_cols]\n",
    "    y = df[\"risk_label\"]\n",
    "\n",
    "    X_train, X_test, y_train, y_test = train_test_split(\n",
    "        X, y, test_size=0.25, random_state=42, stratify=y\n",
    "    )\n",
    "\n",
    "    model = RandomForestClassifier(\n",
    "        n_estimators=300,\n",
    "        max_depth=8,\n",
    "        random_state=42,\n",
    "        class_weight=\"balanced\"\n",
    "    )\n",
    "\n",
    "    model.fit(X_train, y_train)\n",
    "\n",
    "    y_pred = model.predict(X_test)\n",
    "    y_prob = model.predict_proba(X_test)\n",
    "\n",
    "    return model, X_train, X_test, y_train, y_test, y_pred, y_prob, feature_cols\n",
    "\n",
    "\n",
    "# --------------------------------------------------\n",
    "# 5. Create predicted supplier output\n",
    "# --------------------------------------------------\n",
    "def build_supplier_risk_output(df: pd.DataFrame, model, feature_cols):\n",
    "    out = df.copy()\n",
    "\n",
    "    probs = model.predict_proba(out[feature_cols])\n",
    "    preds = model.predict(out[feature_cols])\n",
    "\n",
    "    out[\"predicted_risk_label\"] = preds\n",
    "    out[\"pred_low_risk_prob\"] = probs[:, 0]\n",
    "    out[\"pred_medium_risk_prob\"] = probs[:, 1]\n",
    "    out[\"pred_high_risk_prob\"] = probs[:, 2]\n",
    "\n",
    "    risk_map = {0: \"Low Risk\", 1: \"Medium Risk\", 2: \"High Risk\"}\n",
    "    out[\"predicted_risk_category\"] = out[\"predicted_risk_label\"].map(risk_map)\n",
    "\n",
    "    # High-risk alert\n",
    "    out[\"risk_alert\"] = np.where(\n",
    "        out[\"predicted_risk_category\"] == \"High Risk\",\n",
    "        \"High Supplier Risk\",\n",
    "        \"Normal\"\n",
    "    )\n",
    "\n",
    "    return out\n",
    "\n",
    "\n",
    "# --------------------------------------------------\n",
    "# 6. Add policy alert layers\n",
    "# --------------------------------------------------\n",
    "def add_policy_alerts(out_df: pd.DataFrame) -> pd.DataFrame:\n",
    "    out = out_df.copy()\n",
    "\n",
    "    # Alert 1: High supplier risk\n",
    "    out[\"high_supplier_risk_alert\"] = np.where(\n",
    "        out[\"predicted_risk_category\"] == \"High Risk\",\n",
    "        \"High Supplier Risk\",\n",
    "        \"Normal\"\n",
    "    )\n",
    "\n",
    "    # Alert 2: Supply concentration risk\n",
    "    out[\"supply_concentration_alert\"] = np.where(\n",
    "        (out[\"single_source_flag\"] == 1) & (out[\"predicted_risk_category\"].isin([\"Medium Risk\", \"High Risk\"])),\n",
    "        \"Single Source Exposure\",\n",
    "        \"Normal\"\n",
    "    )\n",
    "\n",
    "    def summarize(row):\n",
    "        alerts = []\n",
    "        if row[\"high_supplier_risk_alert\"] == \"High Supplier Risk\":\n",
    "            alerts.append(\"High Supplier Risk\")\n",
    "        if row[\"supply_concentration_alert\"] == \"Single Source Exposure\":\n",
    "            alerts.append(\"Single Source Exposure\")\n",
    "        return \" | \".join(alerts) if alerts else \"Normal\"\n",
    "\n",
    "    out[\"policy_alert_summary\"] = out.apply(summarize, axis=1)\n",
    "    return out\n",
    "\n",
    "\n",
    "# --------------------------------------------------\n",
    "# 7. Plot feature importance\n",
    "# --------------------------------------------------\n",
    "def plot_feature_importance(model, feature_cols):\n",
    "    importances = model.feature_importances_\n",
    "    idx = np.argsort(importances)[::-1]\n",
    "\n",
    "    plt.figure(figsize=(10, 6))\n",
    "    plt.bar(range(len(feature_cols)), importances[idx])\n",
    "    plt.xticks(range(len(feature_cols)), np.array(feature_cols)[idx], rotation=45, ha=\"right\")\n",
    "    plt.title(\"Supplier Risk Model - Feature Importance\")\n",
    "    plt.ylabel(\"Importance\")\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "\n",
    "# --------------------------------------------------\n",
    "# 8. Plot predicted risk category counts\n",
    "# --------------------------------------------------\n",
    "def plot_risk_distribution(out_df: pd.DataFrame):\n",
    "    counts = out_df[\"predicted_risk_category\"].value_counts()\n",
    "\n",
    "    plt.figure(figsize=(7, 5))\n",
    "    plt.bar(counts.index, counts.values)\n",
    "    plt.title(\"Predicted Supplier Risk Distribution\")\n",
    "    plt.xlabel(\"Risk Category\")\n",
    "    plt.ylabel(\"Supplier Count\")\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "\n",
    "# --------------------------------------------------\n",
    "# Main demo\n",
    "# --------------------------------------------------\n",
    "if __name__ == \"__main__\":\n",
    "    # Step 1: Generate dataset\n",
    "    df = make_synthetic_supplier_data(n_suppliers=300)\n",
    "\n",
    "    print(\"\\nSynthetic supplier sample:\")\n",
    "    print(df.head())\n",
    "\n",
    "    # Step 2: Train model\n",
    "    model, X_train, X_test, y_train, y_test, y_pred, y_prob, feature_cols = train_supplier_risk_model(df)\n",
    "\n",
    "    print(\"\\nModel accuracy:\")\n",
    "    print(round(accuracy_score(y_test, y_pred), 4))\n",
    "\n",
    "    print(\"\\nClassification report:\")\n",
    "    print(classification_report(y_test, y_pred, target_names=[\"Low Risk\", \"Medium Risk\", \"High Risk\"]))\n",
    "\n",
    "    print(\"\\nConfusion matrix:\")\n",
    "    print(confusion_matrix(y_test, y_pred))\n",
    "\n",
    "    # Step 3: Predict all suppliers\n",
    "    out_df = build_supplier_risk_output(df, model, feature_cols)\n",
    "    out_df = add_policy_alerts(out_df)\n",
    "\n",
    "    print(\"\\nSupplier risk output sample:\")\n",
    "    print(out_df[[\n",
    "        \"supplier_id\",\n",
    "        \"otd_pct\",\n",
    "        \"quality_ppm\",\n",
    "        \"lead_time_days\",\n",
    "        \"lead_time_std\",\n",
    "        \"financial_score\",\n",
    "        \"single_source_flag\",\n",
    "        \"geo_risk_score\",\n",
    "        \"predicted_risk_category\",\n",
    "        \"pred_high_risk_prob\",\n",
    "        \"policy_alert_summary\"\n",
    "    ]].head(15))\n",
    "\n",
    "    # Step 4: Show alert suppliers only\n",
    "    alert_df = out_df[out_df[\"policy_alert_summary\"] != \"Normal\"].copy()\n",
    "\n",
    "    print(\"\\nAlert supplier list:\")\n",
    "    print(alert_df[[\n",
    "        \"supplier_id\",\n",
    "        \"predicted_risk_category\",\n",
    "        \"pred_high_risk_prob\",\n",
    "        \"single_source_flag\",\n",
    "        \"policy_alert_summary\"\n",
    "    ]].sort_values([\"pred_high_risk_prob\"], ascending=False).head(20))\n",
    "\n",
    "    # Step 5: Visualizations\n",
    "    plot_feature_importance(model, feature_cols)\n",
    "    plot_risk_distribution(out_df)"
   ]
