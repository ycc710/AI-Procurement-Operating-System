    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "from sklearn.model_selection import TimeSeriesSplit\n",
    "from sklearn.metrics import mean_absolute_error, mean_squared_error\n",
    "from sklearn.ensemble import HistGradientBoostingRegressor\n",
    "\n",
    "\n",
    "# ----------------------------\n",
    "# 1) Synthetic dataset generator\n",
    "# ----------------------------\n",
    "def make_synthetic_demand_data(\n",
    "    start=\"2022-01-01\",\n",
    "    end=\"2025-01-01\",\n",
    "    n_skus=12,\n",
    "    seed=42\n",
    ") -> pd.DataFrame:\n",
    "    \"\"\"\n",
    "    Creates realistic-ish daily demand data for multiple SKUs with:\n",
    "      - weekly & yearly seasonality\n",
    "      - trend\n",
    "      - price elasticity\n",
    "      - promotions\n",
    "      - holiday spikes\n",
    "      - random noise\n",
    "    Output columns:\n",
    "      date, sku, demand, price, promo, is_holiday\n",
    "    \"\"\"\n",
    "    rng = np.random.default_rng(seed)\n",
    "    dates = pd.date_range(start=start, end=end, freq=\"D\", inclusive=\"left\")\n",
    "    n_days = len(dates)\n",
    "\n",
    "    # Simple holiday set (you can expand later)\n",
    "    holidays = set(pd.to_datetime([\n",
    "        \"2022-01-01\", \"2022-12-25\", \"2022-11-24\",\n",
    "        \"2023-01-01\", \"2023-12-25\", \"2023-11-23\",\n",
    "        \"2024-01-01\", \"2024-12-25\", \"2024-11-28\",\n",
    "    ]).date)\n",
    "\n",
    "    rows = []\n",
    "    for i in range(n_skus):\n",
    "        sku = f\"SKU{i+1:02d}\"\n",
    "\n",
    "        base = rng.uniform(30, 180)                     # baseline demand level\n",
    "        trend = rng.uniform(-0.015, 0.03)               # daily trend rate-ish (small)\n",
    "        weekly_amp = rng.uniform(0.05, 0.25)            # weekly seasonality amplitude\n",
    "        yearly_amp = rng.uniform(0.05, 0.35)            # yearly seasonality amplitude\n",
    "\n",
    "        # Price + elasticity\n",
    "        base_price = rng.uniform(10, 120)\n",
    "        price_vol = rng.uniform(0.02, 0.12)\n",
    "        elasticity = rng.uniform(-2.0, -0.2)            # negative elasticity\n",
    "\n",
    "        # Promo effect\n",
    "        promo_lift = rng.uniform(0.15, 0.60)\n",
    "\n",
    "        # Generate per-day series\n",
    "        t = np.arange(n_days)\n",
    "\n",
    "        # price random walk\n",
    "        price = base_price * np.exp(np.cumsum(rng.normal(0, price_vol / np.sqrt(365), size=n_days)))\n",
    "        price = np.clip(price, a_min=0.5, a_max=None)\n",
    "\n",
    "        # promotions: random blocks\n",
    "        promo = np.zeros(n_days, dtype=int)\n",
    "        n_campaigns = rng.integers(8, 18)\n",
    "        for _ in range(n_campaigns):\n",
    "            start_idx = int(rng.integers(0, n_days - 10))\n",
    "            length = int(rng.integers(3, 12))\n",
    "            promo[start_idx:start_idx + length] = 1\n",
    "\n",
    "        # holiday flag\n",
    "        is_holiday = np.array([d.date() in holidays for d in dates], dtype=int)\n",
    "\n",
    "        # seasonality\n",
    "        dow = pd.Series(dates).dt.dayofweek.to_numpy()          # 0..6\n",
    "        weekly = 1 + weekly_amp * np.sin(2 * np.pi * dow / 7.0)\n",
    "\n",
    "        doy = pd.Series(dates).dt.dayofyear.to_numpy()\n",
    "        yearly = 1 + yearly_amp * np.sin(2 * np.pi * doy / 365.25)\n",
    "\n",
    "        # trend component (bounded)\n",
    "        trend_factor = 1 + trend * (t / n_days) * 5\n",
    "\n",
    "        # price impact (relative to its mean)\n",
    "        price_rel = price / price.mean()\n",
    "        price_factor = np.power(price_rel, elasticity)\n",
    "\n",
    "        promo_factor = 1 + promo * promo_lift\n",
    "        holiday_factor = 1 + is_holiday * rng.uniform(0.3, 1.0)\n",
    "\n",
    "        # demand with noise\n",
    "        mean_demand = base * weekly * yearly * trend_factor * price_factor * promo_factor * holiday_factor\n",
    "        noise = rng.normal(0, 0.12, size=n_days)  # multiplicative-ish noise\n",
    "        demand = mean_demand * (1 + noise)\n",
    "        demand = np.clip(demand, a_min=0, a_max=None)\n",
    "\n",
    "        sku_df = pd.DataFrame({\n",
    "            \"date\": dates,\n",
    "            \"sku\": sku,\n",
    "            \"demand\": demand,\n",
    "            \"price\": price,\n",
    "            \"promo\": promo,\n",
    "            \"is_holiday\": is_holiday\n",
    "        })\n",
    "        rows.append(sku_df)\n",
    "\n",
    "    df = pd.concat(rows, ignore_index=True)\n",
    "    return df\n",
    "\n",
    "\n",
    "# ----------------------------\n",
    "# 2) Feature engineering (no leakage)\n",
    "# ----------------------------\n",
    "def add_time_features(df: pd.DataFrame) -> pd.DataFrame:\n",
    "    out = df.copy()\n",
    "    out[\"dow\"] = out[\"date\"].dt.dayofweek\n",
    "    out[\"weekofyear\"] = out[\"date\"].dt.isocalendar().week.astype(int)\n",
    "    out[\"month\"] = out[\"date\"].dt.month\n",
    "    out[\"day\"] = out[\"date\"].dt.day\n",
    "    out[\"is_weekend\"] = (out[\"dow\"] >= 5).astype(int)\n",
    "    return out\n",
    "\n",
    "\n",
    "def add_lag_roll_features(df: pd.DataFrame, group_col=\"sku\") -> pd.DataFrame:\n",
    "    \"\"\"\n",
    "    Adds lags and rolling stats for demand & price.\n",
    "    Important: must be computed per SKU and shifted to avoid leakage.\n",
    "    \"\"\"\n",
    "    out = df.sort_values([\"sku\", \"date\"]).copy()\n",
    "\n",
    "    # Demand lags\n",
    "    for lag in [1, 7, 14, 28]:\n",
    "        out[f\"demand_lag_{lag}\"] = out.groupby(group_col)[\"demand\"].shift(lag)\n",
    "\n",
    "    # Rolling demand (shifted by 1 day)\n",
    "    out[\"demand_roll_mean_7\"] = (\n",
    "        out.groupby(group_col)[\"demand\"]\n",
    "        .shift(1)\n",
    "        .rolling(7)\n",
    "        .mean()\n",
    "        .reset_index(level=0, drop=True)\n",
    "    )\n",
    "    out[\"demand_roll_mean_28\"] = (\n",
    "        out.groupby(group_col)[\"demand\"]\n",
    "        .shift(1)\n",
    "        .rolling(28)\n",
    "        .mean()\n",
    "        .reset_index(level=0, drop=True)\n",
    "    )\n",
    "    out[\"demand_roll_std_28\"] = (\n",
    "        out.groupby(group_col)[\"demand\"]\n",
    "        .shift(1)\n",
    "        .rolling(28)\n",
    "        .std()\n",
    "        .reset_index(level=0, drop=True)\n",
    "    )\n",
    "\n",
    "    # Price features (elasticity proxy)\n",
    "    out[\"price_lag_7\"] = out.groupby(group_col)[\"price\"].shift(7)\n",
    "    out[\"price_roll_mean_28\"] = (\n",
    "        out.groupby(group_col)[\"price\"]\n",
    "        .shift(1)\n",
    "        .rolling(28)\n",
    "        .mean()\n",
    "        .reset_index(level=0, drop=True)\n",
    "    )\n",
    "    out[\"price_change_7\"] = (out[\"price\"] - out[\"price_lag_7\"]) / out[\"price_lag_7\"]\n",
    "\n",
    "    return out\n",
    "\n",
    "\n",
    "# ----------------------------\n",
    "# 3) Metrics\n",
    "# ----------------------------\n",
    "def rmse(y_true, y_pred) -> float:\n",
    "    return float(np.sqrt(mean_squared_error(y_true, y_pred)))\n",
    "\n",
    "def mape(y_true, y_pred) -> float:\n",
    "    y_true = np.array(y_true)\n",
    "    y_pred = np.array(y_pred)\n",
    "    denom = np.clip(np.abs(y_true), 1e-6, None)\n",
    "    return float(np.mean(np.abs((y_true - y_pred) / denom)) * 100.0)\n",
    "\n",
    "def wape(y_true, y_pred) -> float:\n",
    "    y_true = np.array(y_true)\n",
    "    y_pred = np.array(y_pred)\n",
    "    return float(np.sum(np.abs(y_true - y_pred)) / np.sum(np.abs(y_true)) * 100.0)\n",
    "\n",
    "# ----------------------------\n",
    "# 4) Baseline model: seasonal naive (7-day)\n",
    "# ----------------------------\n",
    "def seasonal_naive_7(df: pd.DataFrame) -> pd.Series:\n",
    "    # predict demand as last week's same weekday\n",
    "    return df.groupby(\"sku\")[\"demand\"].shift(7)\n",
    "\n",
    "\n",
    "# ----------------------------\n",
    "# 5) Train + backtest with TimeSeriesSplit\n",
    "# ----------------------------\n",
    "def train_backtest(df: pd.DataFrame):\n",
    "    df = df.copy()\n",
    "    df[\"date\"] = pd.to_datetime(df[\"date\"])\n",
    "\n",
    "    df = add_time_features(df)\n",
    "    df = add_lag_roll_features(df)\n",
    "\n",
    "    # Baseline predictions\n",
    "    df[\"pred_naive7\"] = seasonal_naive_7(df)\n",
    "\n",
    "    # Drop early rows without lag features\n",
    "    feature_cols = [\n",
    "        \"promo\", \"is_holiday\", \"price\", \"dow\", \"weekofyear\", \"month\", \"is_weekend\",\n",
    "        \"demand_lag_1\", \"demand_lag_7\", \"demand_lag_14\", \"demand_lag_28\",\n",
    "        \"demand_roll_mean_7\", \"demand_roll_mean_28\", \"demand_roll_std_28\",\n",
    "        \"price_roll_mean_28\", \"price_change_7\",\n",
    "    ]\n",
    "\n",
    "    model_df = df.dropna(subset=feature_cols + [\"demand\"]).sort_values([\"date\", \"sku\"]).copy()\n",
    "\n",
    "    # Encode sku as category integer (simple; avoids one-hot bloat)\n",
    "    model_df[\"sku_id\"] = model_df[\"sku\"].astype(\"category\").cat.codes\n",
    "    feature_cols2 = feature_cols + [\"sku_id\"]\n",
    "\n",
    "    X = model_df[feature_cols2]\n",
    "    y = model_df[\"demand\"]\n",
    "\n",
    "    # Time-based split (by date). We'll split on the sorted rows,\n",
    "    # which mix SKUs per date but keep time order.\n",
    "    tscv = TimeSeriesSplit(n_splits=5)\n",
    "\n",
    "    fold_metrics = []\n",
    "    oof_pred = pd.Series(index=model_df.index, dtype=float)\n",
    "\n",
    "    for fold, (train_idx, test_idx) in enumerate(tscv.split(X), start=1):\n",
    "        X_train, X_test = X.iloc[train_idx], X.iloc[test_idx]\n",
    "        y_train, y_test = y.iloc[train_idx], y.iloc[test_idx]\n",
    "\n",
    "        model = HistGradientBoostingRegressor(\n",
    "            max_depth=6,\n",
    "            learning_rate=0.06,\n",
    "            max_iter=350,\n",
    "            random_state=42\n",
    "        )\n",
    "        model.fit(X_train, y_train)\n",
    "\n",
    "        pred = model.predict(X_test)\n",
    "        oof_pred.iloc[test_idx] = pred\n",
    "\n",
    "        # Baseline on same rows\n",
    "        naive = model_df.loc[model_df.index[test_idx], \"pred_naive7\"].values\n",
    "\n",
    "        fold_result = {\n",
    "            \"fold\": fold,\n",
    "            \"model_MAE\": mean_absolute_error(y_test, pred),\n",
    "            \"model_RMSE\": rmse(y_test, pred),\n",
    "            \"model_MAPE_%\": mape(y_test, pred),\n",
    "            \"naive7_MAE\": mean_absolute_error(y_test, naive),\n",
    "            \"naive7_RMSE\": rmse(y_test, naive),\n",
    "            \"naive7_MAPE_%\": mape(y_test, naive),\n",
    "        }\n",
    "        fold_metrics.append(fold_result)\n",
    "\n",
    "    metrics_df = pd.DataFrame(fold_metrics)\n",
    "\n",
    "    # Train final model on all data\n",
    "    final_model = HistGradientBoostingRegressor(\n",
    "        max_depth=6,\n",
    "        learning_rate=0.06,\n",
    "        max_iter=350,\n",
    "        random_state=42\n",
    "    )\n",
    "    final_model.fit(X, y)\n",
    "\n",
    "    model_df[\"pred_model\"] = oof_pred\n",
    "\n",
    "    return final_model, model_df, metrics_df, feature_cols2\n",
    "\n",
    "\n",
    "# ----------------------------\n",
    "# 6) Forecast next N days (requires future price/promo plan assumptions)\n",
    "# ----------------------------\n",
    "def forecast_next_days(df_raw: pd.DataFrame, model, horizon_days=28):\n",
    "    \"\"\"\n",
    "    Produces forecasts for each SKU for next horizon_days.\n",
    "    We assume:\n",
    "      - future promo plan = 0 by default\n",
    "      - future price holds last observed price\n",
    "      - holiday flag based on a small hardcoded set (extend later)\n",
    "    \"\"\"\n",
    "    df = df_raw.copy()\n",
    "    df[\"date\"] = pd.to_datetime(df[\"date\"])\n",
    "    df = df.sort_values([\"sku\", \"date\"]).copy()\n",
    "\n",
    "    last_date = df[\"date\"].max()\n",
    "    future_dates = pd.date_range(last_date + pd.Timedelta(days=1), periods=horizon_days, freq=\"D\")\n",
    "\n",
    "    # Create future rows for each SKU\n",
    "    skus = df[\"sku\"].unique()\n",
    "    future_rows = []\n",
    "    for sku in skus:\n",
    "        sku_hist = df[df[\"sku\"] == sku].sort_values(\"date\").copy()\n",
    "        last_price = float(sku_hist[\"price\"].iloc[-1])\n",
    "\n",
    "        # default: no promo; price hold\n",
    "        temp = pd.DataFrame({\n",
    "            \"date\": future_dates,\n",
    "            \"sku\": sku,\n",
    "            \"demand\": np.nan,\n",
    "            \"price\": last_price,\n",
    "            \"promo\": 0,\n",
    "            \"is_holiday\": 0,\n",
    "        })\n",
    "        future_rows.append(temp)\n",
    "\n",
    "    future_df = pd.concat(future_rows, ignore_index=True)\n",
    "\n",
    "    # Combine & build features iteratively (because lagged demand needs predictions)\n",
    "    combined = pd.concat([df, future_df], ignore_index=True).sort_values([\"sku\", \"date\"]).copy()\n",
    "\n",
    "    combined = add_time_features(combined)\n",
    "\n",
    "    # Iterative forecasting per SKU\n",
    "    # We'll compute lag/rolling from available demand, filling future demands with predictions step by step.\n",
    "    preds_out = []\n",
    "\n",
    "    # Prepare sku_id encoding consistent with training\n",
    "    combined[\"sku_id\"] = combined[\"sku\"].astype(\"category\").cat.codes\n",
    "\n",
    "    feature_cols = [\n",
    "        \"promo\", \"is_holiday\", \"price\", \"dow\", \"weekofyear\", \"month\", \"is_weekend\",\n",
    "        \"demand_lag_1\", \"demand_lag_7\", \"demand_lag_14\", \"demand_lag_28\",\n",
    "        \"demand_roll_mean_7\", \"demand_roll_mean_28\", \"demand_roll_std_28\",\n",
    "        \"price_roll_mean_28\", \"price_change_7\",\n",
    "        \"sku_id\"\n",
    "    ]\n",
    "\n",
    "    for sku in skus:\n",
    "        sku_all = combined[combined[\"sku\"] == sku].sort_values(\"date\").copy()\n",
    "\n",
    "        for idx in range(len(sku_all)):\n",
    "            if pd.isna(sku_all[\"demand\"].iloc[idx]):\n",
    "                # recompute lag features for this SKU slice each step\n",
    "                tmp = sku_all.copy()\n",
    "                tmp = add_lag_roll_features(tmp, group_col=\"sku\")\n",
    "\n",
    "                row = tmp.iloc[idx:idx+1].copy()\n",
    "\n",
    "                # fill NaNs in price_change_7 (early horizon) conservatively\n",
    "                row[\"price_change_7\"] = row[\"price_change_7\"].fillna(0.0)\n",
    "\n",
    "                # if still missing lag/rolling (rare if history is long enough), fallback\n",
    "                for c in feature_cols:\n",
    "                    if c not in row.columns:\n",
    "                        row[c] = 0.0\n",
    "                row = row[feature_cols].ffill().fillna(0.0)\n",
    "\n",
    "                pred = float(model.predict(row)[0])\n",
    "                sku_all.loc[sku_all.index[idx], \"demand\"] = max(pred, 0.0)\n",
    "\n",
    "        preds_out.append(sku_all[sku_all[\"date\"].isin(future_dates)][[\"date\", \"sku\", \"demand\"]])\n",
    "\n",
    "    forecast_df = pd.concat(preds_out, ignore_index=True).rename(columns={\"demand\": \"forecast_demand\"})\n",
    "    return forecast_df\n",
    "\n",
    "\n",
    "# ----------------------------\n",
    "# 7) Plotting helpers\n",
    "# ----------------------------\n",
    "def plot_metrics(metrics_df: pd.DataFrame):\n",
    "    print(\"\\nBacktest metrics by fold:\")\n",
    "    print(metrics_df.round(3))\n",
    "\n",
    "    print(\"\\nAverage performance:\")\n",
    "    print(metrics_df.drop(columns=[\"fold\"]).mean().round(3))\n",
    "\n",
    "\n",
    "def plot_example_series(model_df: pd.DataFrame, sku=\"SKU01\", n_days=180):\n",
    "    s = model_df[model_df[\"sku\"] == sku].sort_values(\"date\").copy()\n",
    "    s = s.tail(n_days)\n",
    "\n",
    "    plt.figure(figsize=(10, 5))\n",
    "    plt.plot(s[\"date\"], s[\"demand\"], label=\"Actual\")\n",
    "    plt.plot(s[\"date\"], s[\"pred_naive7\"], label=\"Naive(7)\")\n",
    "    plt.plot(s[\"date\"], s[\"pred_model\"], label=\"Model (OOF)\")\n",
    "    plt.title(f\"Demand Forecast Backtest Example - {sku}\")\n",
    "    plt.xlabel(\"Date\")\n",
    "    plt.ylabel(\"Demand\")\n",
    "    plt.legend()\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "\n",
    "# ----------------------------\n",
    "# Main runnable demo\n",
    "# ----------------------------\n",
    "if __name__ == \"__main__\":\n",
    "    df = make_synthetic_demand_data(start=\"2022-01-01\", end=\"2025-01-01\", n_skus=12)\n",
    "\n",
    "    model, model_df, metrics_df, feature_cols = train_backtest(df)\n",
    "\n",
    "    plot_metrics(metrics_df)\n",
    "    plot_example_series(model_df, sku=\"SKU01\", n_days=240)\n",
    "\n",
    "    # Produce a forward forecast (28 days)\n",
    "    forecast_df = forecast_next_days(df, model, horizon_days=28)\n",
    "    print(\"\\nForecast sample:\")\n",
    "    print(forecast_df.head(10))"
   ]
  }
