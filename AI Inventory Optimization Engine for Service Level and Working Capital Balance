    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "from sklearn.ensemble import HistGradientBoostingRegressor\n",
    "from sklearn.model_selection import TimeSeriesSplit\n",
    "from sklearn.metrics import mean_absolute_error, mean_squared_error\n",
    "\n",
    "\n",
    "# --------------------------------------------------\n",
    "# 1. Synthetic demand generator\n",
    "# --------------------------------------------------\n",
    "def make_synthetic_demand_data(\n",
    "    start=\"2022-01-01\",\n",
    "    end=\"2025-01-01\",\n",
    "    n_skus=12,\n",
    "    seed=42\n",
    ") -> pd.DataFrame:\n",
    "    rng = np.random.default_rng(seed)\n",
    "    dates = pd.date_range(start=start, end=end, freq=\"D\", inclusive=\"left\")\n",
    "    n_days = len(dates)\n",
    "\n",
    "    holidays = set(pd.to_datetime([\n",
    "        \"2022-01-01\", \"2022-12-25\", \"2022-11-24\",\n",
    "        \"2023-01-01\", \"2023-12-25\", \"2023-11-23\",\n",
    "        \"2024-01-01\", \"2024-12-25\", \"2024-11-28\",\n",
    "    ]).date)\n",
    "\n",
    "    rows = []\n",
    "    for i in range(n_skus):\n",
    "        sku = f\"SKU{i+1:02d}\"\n",
    "\n",
    "        base = rng.uniform(30, 180)\n",
    "        trend = rng.uniform(-0.015, 0.03)\n",
    "        weekly_amp = rng.uniform(0.05, 0.25)\n",
    "        yearly_amp = rng.uniform(0.05, 0.35)\n",
    "\n",
    "        base_price = rng.uniform(10, 120)\n",
    "        price_vol = rng.uniform(0.02, 0.12)\n",
    "        elasticity = rng.uniform(-2.0, -0.2)\n",
    "        promo_lift = rng.uniform(0.15, 0.60)\n",
    "\n",
    "        t = np.arange(n_days)\n",
    "\n",
    "        price = base_price * np.exp(np.cumsum(rng.normal(0, price_vol / np.sqrt(365), size=n_days)))\n",
    "        price = np.clip(price, a_min=0.5, a_max=None)\n",
    "\n",
    "        promo = np.zeros(n_days, dtype=int)\n",
    "        n_campaigns = rng.integers(8, 18)\n",
    "        for _ in range(n_campaigns):\n",
    "            start_idx = int(rng.integers(0, n_days - 10))\n",
    "            length = int(rng.integers(3, 12))\n",
    "            promo[start_idx:start_idx + length] = 1\n",
    "\n",
    "        is_holiday = np.array([d.date() in holidays for d in dates], dtype=int)\n",
    "\n",
    "        dow = pd.Series(dates).dt.dayofweek.to_numpy()\n",
    "        weekly = 1 + weekly_amp * np.sin(2 * np.pi * dow / 7.0)\n",
    "\n",
    "        doy = pd.Series(dates).dt.dayofyear.to_numpy()\n",
    "        yearly = 1 + yearly_amp * np.sin(2 * np.pi * doy / 365.25)\n",
    "\n",
    "        trend_factor = 1 + trend * (t / n_days) * 5\n",
    "        price_rel = price / price.mean()\n",
    "        price_factor = np.power(price_rel, elasticity)\n",
    "        promo_factor = 1 + promo * promo_lift\n",
    "        holiday_factor = 1 + is_holiday * rng.uniform(0.3, 1.0)\n",
    "\n",
    "        mean_demand = base * weekly * yearly * trend_factor * price_factor * promo_factor * holiday_factor\n",
    "        noise = rng.normal(0, 0.12, size=n_days)\n",
    "        demand = mean_demand * (1 + noise)\n",
    "        demand = np.clip(demand, a_min=0, a_max=None)\n",
    "\n",
    "        sku_df = pd.DataFrame({\n",
    "            \"date\": dates,\n",
    "            \"sku\": sku,\n",
    "            \"demand\": demand,\n",
    "            \"price\": price,\n",
    "            \"promo\": promo,\n",
    "            \"is_holiday\": is_holiday\n",
    "        })\n",
    "        rows.append(sku_df)\n",
    "\n",
    "    return pd.concat(rows, ignore_index=True)\n",
    "\n",
    "\n",
    "# --------------------------------------------------\n",
    "# 2. Forecasting features\n",
    "# --------------------------------------------------\n",
    "def add_time_features(df: pd.DataFrame) -> pd.DataFrame:\n",
    "    out = df.copy()\n",
    "    out[\"dow\"] = out[\"date\"].dt.dayofweek\n",
    "    out[\"weekofyear\"] = out[\"date\"].dt.isocalendar().week.astype(int)\n",
    "    out[\"month\"] = out[\"date\"].dt.month\n",
    "    out[\"day\"] = out[\"date\"].dt.day\n",
    "    out[\"is_weekend\"] = (out[\"dow\"] >= 5).astype(int)\n",
    "    return out\n",
    "\n",
    "\n",
    "def add_lag_roll_features(df: pd.DataFrame, group_col=\"sku\") -> pd.DataFrame:\n",
    "    out = df.sort_values([group_col, \"date\"]).copy()\n",
    "\n",
    "    for lag in [1, 7, 14, 28]:\n",
    "        out[f\"demand_lag_{lag}\"] = out.groupby(group_col)[\"demand\"].shift(lag)\n",
    "\n",
    "    out[\"demand_roll_mean_7\"] = (\n",
    "        out.groupby(group_col)[\"demand\"].shift(1).rolling(7).mean().reset_index(level=0, drop=True)\n",
    "    )\n",
    "    out[\"demand_roll_mean_28\"] = (\n",
    "        out.groupby(group_col)[\"demand\"].shift(1).rolling(28).mean().reset_index(level=0, drop=True)\n",
    "    )\n",
    "    out[\"demand_roll_std_28\"] = (\n",
    "        out.groupby(group_col)[\"demand\"].shift(1).rolling(28).std().reset_index(level=0, drop=True)\n",
    "    )\n",
    "\n",
    "    out[\"price_lag_7\"] = out.groupby(group_col)[\"price\"].shift(7)\n",
    "    out[\"price_roll_mean_28\"] = (\n",
    "        out.groupby(group_col)[\"price\"].shift(1).rolling(28).mean().reset_index(level=0, drop=True)\n",
    "    )\n",
    "    out[\"price_change_7\"] = (out[\"price\"] - out[\"price_lag_7\"]) / out[\"price_lag_7\"]\n",
    "\n",
    "    return out\n",
    "\n",
    "\n",
    "# --------------------------------------------------\n",
    "# 3. Forecasting model\n",
    "# --------------------------------------------------\n",
    "def train_forecast_model(df: pd.DataFrame):\n",
    "    df = df.copy()\n",
    "    df[\"date\"] = pd.to_datetime(df[\"date\"])\n",
    "\n",
    "    df = add_time_features(df)\n",
    "    df = add_lag_roll_features(df)\n",
    "\n",
    "    feature_cols = [\n",
    "        \"promo\", \"is_holiday\", \"price\", \"dow\", \"weekofyear\", \"month\", \"is_weekend\",\n",
    "        \"demand_lag_1\", \"demand_lag_7\", \"demand_lag_14\", \"demand_lag_28\",\n",
    "        \"demand_roll_mean_7\", \"demand_roll_mean_28\", \"demand_roll_std_28\",\n",
    "        \"price_roll_mean_28\", \"price_change_7\"\n",
    "    ]\n",
    "\n",
    "    model_df = df.dropna(subset=feature_cols + [\"demand\"]).sort_values([\"date\", \"sku\"]).copy()\n",
    "    model_df[\"sku_id\"] = model_df[\"sku\"].astype(\"category\").cat.codes\n",
    "    feature_cols2 = feature_cols + [\"sku_id\"]\n",
    "\n",
    "    X = model_df[feature_cols2]\n",
    "    y = model_df[\"demand\"]\n",
    "\n",
    "    model = HistGradientBoostingRegressor(\n",
    "        max_depth=6,\n",
    "        learning_rate=0.06,\n",
    "        max_iter=350,\n",
    "        random_state=42\n",
    "    )\n",
    "    model.fit(X, y)\n",
    "    return model, feature_cols2\n",
    "\n",
    "\n",
    "def forecast_next_days(df_raw: pd.DataFrame, model, horizon_days=28):\n",
    "    df = df_raw.copy()\n",
    "    df[\"date\"] = pd.to_datetime(df[\"date\"])\n",
    "    df = df.sort_values([\"sku\", \"date\"]).copy()\n",
    "\n",
    "    last_date = df[\"date\"].max()\n",
    "    future_dates = pd.date_range(last_date + pd.Timedelta(days=1), periods=horizon_days, freq=\"D\")\n",
    "\n",
    "    skus = df[\"sku\"].unique()\n",
    "    future_rows = []\n",
    "    for sku in skus:\n",
    "        sku_hist = df[df[\"sku\"] == sku].sort_values(\"date\").copy()\n",
    "        last_price = float(sku_hist[\"price\"].iloc[-1])\n",
    "\n",
    "        temp = pd.DataFrame({\n",
    "            \"date\": future_dates,\n",
    "            \"sku\": sku,\n",
    "            \"demand\": np.nan,\n",
    "            \"price\": last_price,\n",
    "            \"promo\": 0,\n",
    "            \"is_holiday\": 0,\n",
    "        })\n",
    "        future_rows.append(temp)\n",
    "\n",
    "    future_df = pd.concat(future_rows, ignore_index=True)\n",
    "\n",
    "    combined = pd.concat([df, future_df], ignore_index=True).sort_values([\"sku\", \"date\"]).copy()\n",
    "    combined = add_time_features(combined)\n",
    "    combined[\"sku_id\"] = combined[\"sku\"].astype(\"category\").cat.codes\n",
    "\n",
    "    feature_cols = [\n",
    "        \"promo\", \"is_holiday\", \"price\", \"dow\", \"weekofyear\", \"month\", \"is_weekend\",\n",
    "        \"demand_lag_1\", \"demand_lag_7\", \"demand_lag_14\", \"demand_lag_28\",\n",
    "        \"demand_roll_mean_7\", \"demand_roll_mean_28\", \"demand_roll_std_28\",\n",
    "        \"price_roll_mean_28\", \"price_change_7\", \"sku_id\"\n",
    "    ]\n",
    "\n",
    "    preds_out = []\n",
    "\n",
    "    for sku in skus:\n",
    "        sku_all = combined[combined[\"sku\"] == sku].sort_values(\"date\").copy()\n",
    "\n",
    "        for idx in range(len(sku_all)):\n",
    "            if pd.isna(sku_all[\"demand\"].iloc[idx]):\n",
    "                tmp = sku_all.copy()\n",
    "                tmp = add_lag_roll_features(tmp, group_col=\"sku\")\n",
    "\n",
    "                row = tmp.iloc[idx:idx+1].copy()\n",
    "                row[\"price_change_7\"] = row[\"price_change_7\"].fillna(0.0)\n",
    "\n",
    "                for c in feature_cols:\n",
    "                    if c not in row.columns:\n",
    "                        row[c] = 0.0\n",
    "\n",
    "                row = row[feature_cols].ffill().fillna(0.0)\n",
    "                pred = float(model.predict(row)[0])\n",
    "                sku_all.loc[sku_all.index[idx], \"demand\"] = max(pred, 0.0)\n",
    "\n",
    "        preds_out.append(sku_all[sku_all[\"date\"].isin(future_dates)][[\"date\", \"sku\", \"demand\"]])\n",
    "\n",
    "    forecast_df = pd.concat(preds_out, ignore_index=True).rename(columns={\"demand\": \"forecast_demand\"})\n",
    "    return forecast_df\n",
    "\n",
    "\n",
    "# --------------------------------------------------\n",
    "# 4. Inventory optimization logic\n",
    "# --------------------------------------------------\n",
    "def z_value_for_service_level(service_level: float) -> float:\n",
    "    z_map = {\n",
    "        0.90: 1.28,\n",
    "        0.95: 1.65,\n",
    "        0.98: 2.05,\n",
    "        0.99: 2.33\n",
    "    }\n",
    "    if service_level not in z_map:\n",
    "        raise ValueError(\"Use one of: 0.90, 0.95, 0.98, 0.99\")\n",
    "    return z_map[service_level]\n",
    "\n",
    "\n",
    "def build_inventory_parameters(df_history: pd.DataFrame, forecast_df: pd.DataFrame, seed=42) -> pd.DataFrame:\n",
    "    \"\"\"\n",
    "    Creates inventory optimization inputs per SKU:\n",
    "      - avg_daily_demand\n",
    "      - std_daily_demand\n",
    "      - lead_time_days\n",
    "      - unit_cost\n",
    "      - order_cost\n",
    "      - annual_holding_rate\n",
    "    \"\"\"\n",
    "    rng = np.random.default_rng(seed)\n",
    "\n",
    "    hist_stats = (\n",
    "        df_history.groupby(\"sku\")[\"demand\"]\n",
    "        .agg(avg_daily_demand=\"mean\", std_daily_demand=\"std\")\n",
    "        .reset_index()\n",
    "    )\n",
    "\n",
    "    # 28-day forecast average as near-future planning signal\n",
    "    fc_stats = (\n",
    "        forecast_df.groupby(\"sku\")[\"forecast_demand\"]\n",
    "        .agg(forecast_avg_daily=\"mean\")\n",
    "        .reset_index()\n",
    "    )\n",
    "\n",
    "    params = hist_stats.merge(fc_stats, on=\"sku\", how=\"left\")\n",
    "\n",
    "    # synthetic procurement/business inputs\n",
    "    params[\"lead_time_days\"] = rng.integers(7, 31, size=len(params))\n",
    "    params[\"unit_cost\"] = rng.uniform(8, 120, size=len(params)).round(2)\n",
    "    params[\"order_cost\"] = rng.uniform(40, 250, size=len(params)).round(2)\n",
    "    params[\"annual_holding_rate\"] = rng.uniform(0.18, 0.30, size=len(params)).round(3)\n",
    "\n",
    "    return params\n",
    "\n",
    "\n",
    "def inventory_optimize(params_df: pd.DataFrame, service_level=0.95) -> pd.DataFrame:\n",
    "    out = params_df.copy()\n",
    "    z = z_value_for_service_level(service_level)\n",
    "\n",
    "    # use forecast avg daily demand as planning demand\n",
    "    out[\"planning_daily_demand\"] = out[\"forecast_avg_daily\"]\n",
    "\n",
    "    # lead-time demand mean and std\n",
    "    out[\"lead_time_demand_mean\"] = out[\"planning_daily_demand\"] * out[\"lead_time_days\"]\n",
    "    out[\"lead_time_demand_std\"] = out[\"std_daily_demand\"] * np.sqrt(out[\"lead_time_days\"])\n",
    "\n",
    "    # safety stock and reorder point\n",
    "    out[\"safety_stock\"] = z * out[\"lead_time_demand_std\"]\n",
    "    out[\"reorder_point\"] = out[\"lead_time_demand_mean\"] + out[\"safety_stock\"]\n",
    "\n",
    "    # annual demand for EOQ\n",
    "    out[\"annual_demand\"] = out[\"planning_daily_demand\"] * 365\n",
    "    out[\"holding_cost_per_unit\"] = out[\"unit_cost\"] * out[\"annual_holding_rate\"]\n",
    "\n",
    "    # EOQ\n",
    "    out[\"eoq\"] = np.sqrt(\n",
    "        (2 * out[\"annual_demand\"] * out[\"order_cost\"]) / out[\"holding_cost_per_unit\"]\n",
    "    )\n",
    "\n",
    "    # target inventory position\n",
    "    out[\"target_inventory\"] = out[\"reorder_point\"] + out[\"eoq\"]\n",
    "\n",
    "    # estimated inventory value\n",
    "    out[\"safety_stock_value\"] = out[\"safety_stock\"] * out[\"unit_cost\"]\n",
    "    out[\"target_inventory_value\"] = out[\"target_inventory\"] * out[\"unit_cost\"]\n",
    "\n",
    "    return out.round(2)\n",
    "\n",
    "def add_policy_alerts(opt_df: pd.DataFrame,\n",
    "                      inventory_value_pct: float = 0.80,\n",
    "                      safety_stock_pct: float = 0.80) -> pd.DataFrame:\n",
    "    \"\"\"\n",
    "    Adds policy alert flags:\n",
    "      - High Inventory Value\n",
    "      - High Safety Stock Exposure\n",
    "    Thresholds are percentile-based.\n",
    "    \"\"\"\n",
    "    out = opt_df.copy()\n",
    "\n",
    "    inventory_threshold = out[\"target_inventory_value\"].quantile(inventory_value_pct)\n",
    "    safety_stock_threshold = out[\"safety_stock_value\"].quantile(safety_stock_pct)\n",
    "\n",
    "    out[\"high_inventory_value_alert\"] = np.where(\n",
    "        out[\"target_inventory_value\"] >= inventory_threshold,\n",
    "        \"High Inventory Value\",\n",
    "        \"Normal\"\n",
    "    )\n",
    "\n",
    "    out[\"high_safety_stock_alert\"] = np.where(\n",
    "        out[\"safety_stock_value\"] >= safety_stock_threshold,\n",
    "        \"High Safety Stock Exposure\",\n",
    "        \"Normal\"\n",
    "    )\n",
    "\n",
    "    return out\n",
    "\n",
    "\n",
    "def add_combined_alert_summary(opt_df: pd.DataFrame) -> pd.DataFrame:\n",
    "    out = opt_df.copy()\n",
    "\n",
    "    def combine_alerts(row):\n",
    "        alerts = []\n",
    "        if row[\"high_inventory_value_alert\"] == \"High Inventory Value\":\n",
    "            alerts.append(\"High Inventory Value\")\n",
    "        if row[\"high_safety_stock_alert\"] == \"High Safety Stock Exposure\":\n",
    "            alerts.append(\"High Safety Stock Exposure\")\n",
    "\n",
    "        if not alerts:\n",
    "            return \"Normal\"\n",
    "        return \" | \".join(alerts)\n",
    "\n",
    "    out[\"policy_alert_summary\"] = out.apply(combine_alerts, axis=1)\n",
    "    return out\n",
    "\n",
    "def add_alert_count(opt_df: pd.DataFrame) -> pd.DataFrame:\n",
    "    out = opt_df.copy()\n",
    "    out[\"alert_count\"] = 0\n",
    "    out[\"alert_count\"] += (out[\"high_inventory_value_alert\"] == \"High Inventory Value\").astype(int)\n",
    "    out[\"alert_count\"] += (out[\"high_safety_stock_alert\"] == \"High Safety Stock Exposure\").astype(int)\n",
    "    return out\n",
    "\n",
    "opt_df = add_policy_alerts(opt_df)\n",
    "opt_df = add_combined_alert_summary(opt_df)\n",
    "opt_df = add_alert_count(opt_df)\n",
    "\n",
    "# --------------------------------------------------\n",
    "# 5. Compare multiple service levels\n",
    "# --------------------------------------------------\n",
    "def compare_service_levels(params_df: pd.DataFrame, service_levels=(0.90, 0.95, 0.98, 0.99)) -> pd.DataFrame:\n",
    "    rows = []\n",
    "    for sl in service_levels:\n",
    "        temp = inventory_optimize(params_df, service_level=sl)\n",
    "        row = {\n",
    "            \"service_level\": sl,\n",
    "            \"avg_safety_stock\": temp[\"safety_stock\"].mean(),\n",
    "            \"avg_reorder_point\": temp[\"reorder_point\"].mean(),\n",
    "            \"avg_target_inventory\": temp[\"target_inventory\"].mean(),\n",
    "            \"total_target_inventory_value\": temp[\"target_inventory_value\"].sum(),\n",
    "            \"total_safety_stock_value\": temp[\"safety_stock_value\"].sum(),\n",
    "        }\n",
    "        rows.append(row)\n",
    "\n",
    "    return pd.DataFrame(rows).round(2)\n",
    "\n",
    "\n",
    "# --------------------------------------------------\n",
    "# 6. Visualization\n",
    "# --------------------------------------------------\n",
    "def plot_service_level_tradeoff(service_df: pd.DataFrame):\n",
    "    plt.figure(figsize=(8, 5))\n",
    "    plt.plot(service_df[\"service_level\"], service_df[\"total_target_inventory_value\"], marker=\"o\")\n",
    "    plt.title(\"Service Level vs Total Target Inventory Value\")\n",
    "    plt.xlabel(\"Service Level\")\n",
    "    plt.ylabel(\"Total Target Inventory Value\")\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "\n",
    "def plot_top_safety_stock(opt_df: pd.DataFrame, top_n=10):\n",
    "    temp = opt_df.sort_values(\"safety_stock_value\", ascending=False).head(top_n)\n",
    "\n",
    "    plt.figure(figsize=(10, 5))\n",
    "    plt.bar(temp[\"sku\"], temp[\"safety_stock_value\"])\n",
    "    plt.title(f\"Top {top_n} SKUs by Safety Stock Value\")\n",
    "    plt.xlabel(\"SKU\")\n",
    "    plt.ylabel(\"Safety Stock Value\")\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "\n",
