   "source": [
    "from dataclasses import dataclass, asdict\n",
    "\n",
    "\n",
    "@dataclass\n",
    "class BMWDisplaySmartKeyCostInput:\n",
    "    # Business volume\n",
    "    annual_volume: int\n",
    "\n",
    "    # Mechanical / cosmetic parts\n",
    "    upper_housing_base_cost: float\n",
    "    lower_housing_base_cost: float\n",
    "    key_blade_cost: float\n",
    "    button_set_cost: float\n",
    "    side_trim_substrate_cost: float\n",
    "    side_trim_metallic_finish_cost: float\n",
    "    cosmetic_inspection_cost: float\n",
    "    surface_finish_cost: float\n",
    "\n",
    "    # Electronics\n",
    "    lcd_module_cost: float\n",
    "    pcb_cost: float\n",
    "    mcu_cost: float\n",
    "    rf_chip_cost: float\n",
    "    passive_components_cost: float\n",
    "    battery_power_module_cost: float\n",
    "    connector_fpc_cost: float\n",
    "    power_management_cost: float\n",
    "\n",
    "    # Manufacturing / process\n",
    "    smt_cost: float\n",
    "    pcb_assembly_cost: float\n",
    "    final_assembly_cost: float\n",
    "    lcd_fitting_cost: float\n",
    "    flashing_programming_cost: float\n",
    "    functional_test_cost: float\n",
    "\n",
    "    # Quality / compliance\n",
    "    validation_amortization_per_unit: float\n",
    "    automotive_quality_compliance_cost: float\n",
    "    warranty_reserve_rate: float\n",
    "\n",
    "    # Packaging / logistics / tooling\n",
    "    packaging_cost: float\n",
    "    logistics_cost: float\n",
    "    tooling_cost_total: float\n",
    "    tooling_amortization_volume: int\n",
    "\n",
    "    # Commercial\n",
    "    overhead_rate: float\n",
    "    profit_margin_rate: float\n",
    "\n",
    "    # Optional quote comparison\n",
    "    supplier_quoted_price: float = 0.0\n",
    "\n",
    "\n",
    "def validate_inputs(data: BMWDisplaySmartKeyCostInput) -> None:\n",
    "    if data.annual_volume <= 0:\n",
    "        raise ValueError(\"annual_volume must be greater than 0.\")\n",
    "    if data.tooling_amortization_volume <= 0:\n",
    "        raise ValueError(\"tooling_amortization_volume must be greater than 0.\")\n",
    "\n",
    "    rate_fields = {\n",
    "        \"warranty_reserve_rate\": data.warranty_reserve_rate,\n",
    "        \"overhead_rate\": data.overhead_rate,\n",
    "        \"profit_margin_rate\": data.profit_margin_rate,\n",
    "    }\n",
    "\n",
    "    for field_name, value in rate_fields.items():\n",
    "        if not 0 <= value < 1:\n",
    "            raise ValueError(f\"{field_name} must be between 0 and 1.\")\n",
    "\n",
    "\n",
    "def calculate_tooling_amortization(tooling_cost_total: float, tooling_amortization_volume: int) -> float:\n",
    "    return tooling_cost_total / tooling_amortization_volume\n",
    "\n",
    "\n",
    "def calculate_mechanical_cosmetic_cost(data: BMWDisplaySmartKeyCostInput) -> float:\n",
    "    \"\"\"\n",
    "    Premium cosmetic/mechanical cost structure:\n",
    "    - housing base parts\n",
    "    - key blade\n",
    "    - button set\n",
    "    - VAVE side trim structure:\n",
    "      substrate plastic + metallic-feel finish\n",
    "    - additional cosmetic inspection and surface finish\n",
    "    \"\"\"\n",
    "    return (\n",
    "        data.upper_housing_base_cost\n",
    "        + data.lower_housing_base_cost\n",
    "        + data.key_blade_cost\n",
    "        + data.button_set_cost\n",
    "        + data.side_trim_substrate_cost\n",
    "        + data.side_trim_metallic_finish_cost\n",
    "        + data.cosmetic_inspection_cost\n",
    "        + data.surface_finish_cost\n",
    "    )\n",
    "\n",
    "\n",
    "def calculate_electronics_cost(data: BMWDisplaySmartKeyCostInput) -> float:\n",
    "    return (\n",
    "        data.lcd_module_cost\n",
    "        + data.pcb_cost\n",
    "        + data.mcu_cost\n",
    "        + data.rf_chip_cost\n",
    "        + data.passive_components_cost\n",
    "        + data.battery_power_module_cost\n",
    "        + data.connector_fpc_cost\n",
    "        + data.power_management_cost\n",
    "    )\n",
    "\n",
    "\n",
    "def calculate_process_cost(data: BMWDisplaySmartKeyCostInput) -> float:\n",
    "    return (\n",
    "        data.smt_cost\n",
    "        + data.pcb_assembly_cost\n",
    "        + data.final_assembly_cost\n",
    "        + data.lcd_fitting_cost\n",
    "        + data.flashing_programming_cost\n",
    "        + data.functional_test_cost\n",
    "    )\n",
    "\n",
    "\n",
    "def calculate_base_should_cost(data: BMWDisplaySmartKeyCostInput) -> dict:\n",
    "    validate_inputs(data)\n",
    "\n",
    "    mechanical_cosmetic_cost = calculate_mechanical_cosmetic_cost(data)\n",
    "    electronics_cost = calculate_electronics_cost(data)\n",
    "    process_cost = calculate_process_cost(data)\n",
    "    tooling_amortization = calculate_tooling_amortization(\n",
    "        data.tooling_cost_total,\n",
    "        data.tooling_amortization_volume\n",
    "    )\n",
    "\n",
    "    direct_cost = (\n",
    "        mechanical_cosmetic_cost\n",
    "        + electronics_cost\n",
    "        + process_cost\n",
    "        + data.validation_amortization_per_unit\n",
    "        + data.automotive_quality_compliance_cost\n",
    "        + tooling_amortization\n",
    "        + data.packaging_cost\n",
    "        + data.logistics_cost\n",
    "    )\n",
    "\n",
    "    warranty_reserve = direct_cost * data.warranty_reserve_rate\n",
    "    subtotal_before_overhead = direct_cost + warranty_reserve\n",
    "    overhead_cost = subtotal_before_overhead * data.overhead_rate\n",
    "    total_before_profit = subtotal_before_overhead + overhead_cost\n",
    "    profit = total_before_profit * data.profit_margin_rate\n",
    "    should_cost = total_before_profit + profit\n",
    "\n",
    "    quote_gap = None\n",
    "    quote_gap_pct = None\n",
    "    if data.supplier_quoted_price > 0:\n",
    "        quote_gap = data.supplier_quoted_price - should_cost\n",
    "        if should_cost != 0:\n",
    "            quote_gap_pct = quote_gap / should_cost\n",
    "\n",
    "    return {\n",
    "        \"input\": asdict(data),\n",
    "        \"mechanical_cosmetic_cost\": round(mechanical_cosmetic_cost, 2),\n",
    "        \"electronics_cost\": round(electronics_cost, 2),\n",
    "        \"process_cost\": round(process_cost, 2),\n",
    "        \"validation_amortization_per_unit\": round(data.validation_amortization_per_unit, 2),\n",
    "        \"automotive_quality_compliance_cost\": round(data.automotive_quality_compliance_cost, 2),\n",
    "        \"tooling_amortization_per_unit\": round(tooling_amortization, 2),\n",
    "        \"packaging_cost\": round(data.packaging_cost, 2),\n",
    "        \"logistics_cost\": round(data.logistics_cost, 2),\n",
    "        \"direct_cost\": round(direct_cost, 2),\n",
    "        \"warranty_reserve\": round(warranty_reserve, 2),\n",
    "        \"subtotal_before_overhead\": round(subtotal_before_overhead, 2),\n",
    "        \"overhead_cost\": round(overhead_cost, 2),\n",
    "        \"total_before_profit\": round(total_before_profit, 2),\n",
    "        \"profit\": round(profit, 2),\n",
    "        \"should_cost\": round(should_cost, 2),\n",
    "        \"supplier_quoted_price\": round(data.supplier_quoted_price, 2),\n",
    "        \"quote_gap\": round(quote_gap, 2) if quote_gap is not None else None,\n",
    "        \"quote_gap_pct\": round(quote_gap_pct * 100, 2) if quote_gap_pct is not None else None,\n",
    "    }\n",
    "\n",
    "\n",
    "def get_volume_discount_factor(annual_volume: int) -> float:\n",
    "    \"\"\"\n",
    "    Example procurement assumption:\n",
    "    - <100k: 0%\n",
    "    - 100k~249k: 2%\n",
    "    - 250k~499k: 4%\n",
    "    - >=500k: 6%\n",
    "    \"\"\"\n",
    "    if annual_volume < 100_000:\n",
    "        return 0.00\n",
    "    elif annual_volume < 250_000:\n",
    "        return 0.02\n",
    "    elif annual_volume < 500_000:\n",
    "        return 0.04\n",
    "    return 0.06\n",
    "\n",
    "\n",
    "def calculate_volume_adjusted_should_cost(data: BMWDisplaySmartKeyCostInput) -> dict:\n",
    "    \"\"\"\n",
    "    Volume effect is mainly reflected in:\n",
    "    - electronics sourcing leverage\n",
    "    - manufacturing efficiency\n",
    "    - partial cosmetic processing efficiency\n",
    "    \"\"\"\n",
    "    validate_inputs(data)\n",
    "\n",
    "    discount = get_volume_discount_factor(data.annual_volume)\n",
    "\n",
    "    base_mechanical_cosmetic_cost = calculate_mechanical_cosmetic_cost(data)\n",
    "    base_electronics_cost = calculate_electronics_cost(data)\n",
    "    base_process_cost = calculate_process_cost(data)\n",
    "\n",
    "    adjusted_mechanical_cosmetic_cost = base_mechanical_cosmetic_cost * (1 - discount * 0.25)\n",
    "    adjusted_electronics_cost = base_electronics_cost * (1 - discount)\n",
    "    adjusted_process_cost = base_process_cost * (1 - discount * 0.50)\n",
    "\n",
    "    tooling_amortization = calculate_tooling_amortization(\n",
    "        data.tooling_cost_total,\n",
    "        data.tooling_amortization_volume\n",
    "    )\n",
    "\n",
    "    direct_cost = (\n",
    "        adjusted_mechanical_cosmetic_cost\n",
    "        + adjusted_electronics_cost\n",
    "        + adjusted_process_cost\n",
    "        + data.validation_amortization_per_unit\n",
    "        + data.automotive_quality_compliance_cost\n",
    "        + tooling_amortization\n",
    "        + data.packaging_cost\n",
    "        + data.logistics_cost\n",
    "    )\n",
    "\n",
    "    warranty_reserve = direct_cost * data.warranty_reserve_rate\n",
    "    subtotal_before_overhead = direct_cost + warranty_reserve\n",
    "    overhead_cost = subtotal_before_overhead * data.overhead_rate\n",
    "    total_before_profit = subtotal_before_overhead + overhead_cost\n",
    "    profit = total_before_profit * data.profit_margin_rate\n",
    "    volume_adjusted_should_cost = total_before_profit + profit\n",
    "\n",
    "    return {\n",
    "        \"annual_volume\": data.annual_volume,\n",
    "        \"volume_discount_factor_pct\": round(discount * 100, 2),\n",
    "        \"adjusted_mechanical_cosmetic_cost\": round(adjusted_mechanical_cosmetic_cost, 2),\n",
    "        \"adjusted_electronics_cost\": round(adjusted_electronics_cost, 2),\n",
    "        \"adjusted_process_cost\": round(adjusted_process_cost, 2),\n",
    "        \"volume_adjusted_should_cost\": round(volume_adjusted_should_cost, 2),\n",
    "    }\n",
    "\n",
    "\n",
    "def run_cost_sensitivity_analysis(\n",
    "    data: BMWDisplaySmartKeyCostInput,\n",
    "    lcd_cost_change_pct: float = 0.0,\n",
    "    mcu_cost_change_pct: float = 0.0,\n",
    "    battery_power_module_change_pct: float = 0.0,\n",
    "    side_trim_finish_change_pct: float = 0.0\n",
    ") -> dict:\n",
    "    \"\"\"\n",
    "    Sensitivity analysis for high-impact cost drivers.\n",
    "    Example:\n",
    "    lcd_cost_change_pct = 0.10 means LCD cost increases by 10%\n",
    "    \"\"\"\n",
    "    validate_inputs(data)\n",
    "\n",
    "    modified = BMWDisplaySmartKeyCostInput(**asdict(data))\n",
    "    modified.lcd_module_cost *= (1 + lcd_cost_change_pct)\n",
    "    modified.mcu_cost *= (1 + mcu_cost_change_pct)\n",
    "    modified.battery_power_module_cost *= (1 + battery_power_module_change_pct)\n",
    "    modified.side_trim_metallic_finish_cost *= (1 + side_trim_finish_change_pct)\n",
    "\n",
    "    base_result = calculate_base_should_cost(data)\n",
    "    new_result = calculate_base_should_cost(modified)\n",
    "\n",
    "    cost_delta = new_result[\"should_cost\"] - base_result[\"should_cost\"]\n",
    "    cost_delta_pct = 0.0\n",
    "    if base_result[\"should_cost\"] != 0:\n",
    "        cost_delta_pct = cost_delta / base_result[\"should_cost\"]\n",
    "\n",
    "    return {\n",
    "        \"base_should_cost\": base_result[\"should_cost\"],\n",
    "        \"new_should_cost\": new_result[\"should_cost\"],\n",
    "        \"cost_delta\": round(cost_delta, 2),\n",
    "        \"cost_delta_pct\": round(cost_delta_pct * 100, 2),\n",
    "        \"assumptions\": {\n",
    "            \"lcd_cost_change_pct\": round(lcd_cost_change_pct * 100, 2),\n",
    "            \"mcu_cost_change_pct\": round(mcu_cost_change_pct * 100, 2),\n",
    "            \"battery_power_module_change_pct\": round(battery_power_module_change_pct * 100, 2),\n",
    "            \"side_trim_finish_change_pct\": round(side_trim_finish_change_pct * 100, 2),\n",
    "        }\n",
    "    }\n",
    "\n",
    "\n",
    "def compare_trim_design_scenarios(\n",
    "    data: BMWDisplaySmartKeyCostInput,\n",
    "    aluminum_trim_cost: float,\n",
    "    aluminum_cosmetic_process_cost: float\n",
    ") -> dict:\n",
    "    \"\"\"\n",
    "    Compare original aluminum trim design vs VAVE plastic metallic-feel trim design.\n",
    "\n",
    "    Original aluminum concept:\n",
    "    - aluminum trim material cost\n",
    "    - aluminum cosmetic / finishing process cost\n",
    "\n",
    "    Current VAVE concept in data:\n",
    "    - side_trim_substrate_cost\n",
    "    - side_trim_metallic_finish_cost\n",
    "    \"\"\"\n",
    "    validate_inputs(data)\n",
    "\n",
    "    vave_trim_total = data.side_trim_substrate_cost + data.side_trim_metallic_finish_cost\n",
    "    original_aluminum_trim_total = aluminum_trim_cost + aluminum_cosmetic_process_cost\n",
    "\n",
    "    savings = original_aluminum_trim_total - vave_trim_total\n",
    "    savings_pct = 0.0\n",
    "    if original_aluminum_trim_total != 0:\n",
    "        savings_pct = savings / original_aluminum_trim_total\n",
    "\n",
    "    return {\n",
    "        \"original_aluminum_trim_total\": round(original_aluminum_trim_total, 2),\n",
    "        \"vave_trim_total\": round(vave_trim_total, 2),\n",
    "        \"trim_cost_savings\": round(savings, 2),\n",
    "        \"trim_cost_savings_pct\": round(savings_pct * 100, 2),\n",
    "    }\n",
    "\n",
    "\n",
    "def print_report(title: str, result: dict) -> None:\n",
    "    print(f\"\\n=== {title} ===\")\n",
    "    for key, value in result.items():\n",
    "        print(f\"{key}: {value}\")\n",
    "\n",
    "\n",
    "if __name__ == \"__main__\":\n",
    "    sample_data = BMWDisplaySmartKeyCostInput(\n",
    "        annual_volume=180000,\n",
    "\n",
    "        # Mechanical / cosmetic\n",
    "        upper_housing_base_cost=1.10,\n",
    "        lower_housing_base_cost=1.00,\n",
    "        key_blade_cost=0.85,\n",
    "        button_set_cost=0.42,\n",
    "        side_trim_substrate_cost=0.22,\n",
    "        side_trim_metallic_finish_cost=0.33,\n",
    "        cosmetic_inspection_cost=0.18,\n",
    "        surface_finish_cost=0.28,\n",
    "\n",
    "        # Electronics\n",
    "        lcd_module_cost=4.85,\n",
    "        pcb_cost=1.25,\n",
    "        mcu_cost=2.15,\n",
    "        rf_chip_cost=1.40,\n",
    "        passive_components_cost=0.62,\n",
    "        battery_power_module_cost=1.10,\n",
    "        connector_fpc_cost=0.52,\n",
    "        power_management_cost=0.38,\n",
    "\n",
    "        # Process\n",
    "        smt_cost=0.75,\n",
    "        pcb_assembly_cost=0.58,\n",
    "        final_assembly_cost=0.95,\n",
    "        lcd_fitting_cost=0.48,\n",
    "        flashing_programming_cost=0.25,\n",
    "        functional_test_cost=0.36,\n",
    "\n",
    "        # Quality / compliance\n",
    "        validation_amortization_per_unit=0.72,\n",
    "        automotive_quality_compliance_cost=0.35,\n",
    "        warranty_reserve_rate=0.02,\n",
    "\n",
    "        # Packaging / logistics / tooling\n",
    "        packaging_cost=0.30,\n",
    "        logistics_cost=0.45,\n",
    "        tooling_cost_total=180000.0,\n",
    "        tooling_amortization_volume=300000,\n",
    "\n",
    "        # Commercial\n",
    "        overhead_rate=0.10,\n",
    "        profit_margin_rate=0.08,\n",
    "\n",
    "        # Supplier quote\n",
    "        supplier_quoted_price=23.20\n",
    "    )\n",
    "\n",
    "    base_result = calculate_base_should_cost(sample_data)\n",
    "    volume_result = calculate_volume_adjusted_should_cost(sample_data)\n",
    "    sensitivity_result = run_cost_sensitivity_analysis(\n",
    "        sample_data,\n",
    "        lcd_cost_change_pct=0.10,\n",
    "        mcu_cost_change_pct=0.05,\n",
    "        battery_power_module_change_pct=0.08,\n",
    "        side_trim_finish_change_pct=0.12\n",
    "    )\n",
    "    trim_comparison_result = compare_trim_design_scenarios(\n",
    "        sample_data,\n",
    "        aluminum_trim_cost=0.78,\n",
    "        aluminum_cosmetic_process_cost=0.24\n",
    "    )\n",
    "\n",
    "    print_report(\"BMW Display Smart Key Should-Cost Analysis\", base_result)\n",
    "    print_report(\"Volume Adjusted Should-Cost Analysis\", volume_result)\n",
    "    print_report(\"Sensitivity Analysis\", sensitivity_result)\n",
    "    print_report(\"Trim Design VAVE Comparison\", trim_comparison_result)"
   ]
  }
